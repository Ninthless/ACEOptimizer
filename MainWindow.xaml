<ui:FluentWindow x:Class="ACEOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="ACE Optimizer" Width="580"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        ResizeMode="NoResize"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ui:ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Accent card (glowing) -->
        <Style x:Key="AccentCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
        </Style>

        <!-- Status dot -->
        <Style x:Key="Dot" TargetType="Ellipse">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <SolidColorBrush x:Key="Green"  Color="#22c55e"/>
        <SolidColorBrush x:Key="Amber"  Color="#f59e0b"/>
        <SolidColorBrush x:Key="Gray"   Color="#6b7280"/>
        <SolidColorBrush x:Key="Accent" Color="#3b82f6"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Title="  ACE Optimizer" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- System Tray -->
        <tb:TaskbarIcon x:Name="trayIcon"
                         ToolTipText="{DynamicResource String_TrayRunning}"
                        IconSource="pack://application:,,,/Assets/app.ico"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource String_TrayOpen}" Click="MenuItem_Open_Click"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource String_TrayExit}" Click="MenuItem_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,18,24,18">

            <!-- ── Hero Header ── -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <!-- Active Game Pill -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12"
                        Background="#1d2d50" VerticalAlignment="Center" Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="ShieldLock24" FontSize="26" Foreground="#60a5fa" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="ACE Optimizer" FontSize="20" FontWeight="SemiBold"
                               Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="{DynamicResource String_Subtitle}" FontSize="12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Live active-game pill -->
                <Border x:Name="ActiveGamePill" Grid.Column="2" VerticalAlignment="Center"
                        Background="#0f2a16" CornerRadius="20" Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="PillDot" Style="{StaticResource Dot}" Fill="{StaticResource Gray}"/>
                        <TextBlock x:Name="PillText" Text="No game" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── ACE Status Card ── -->
            <Border Style="{StaticResource AccentCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource String_StatusHeader}" FontSize="10" FontWeight="SemiBold" Opacity="0.5"
                                   Margin="0,0,0,6" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="AceStatusDot" Style="{StaticResource Dot}" Fill="{StaticResource Gray}"/>
                            <TextBlock x:Name="AceStatusText" Text="{DynamicResource String_AceStatusIdle}"
                                       FontSize="14" FontWeight="Medium" VerticalAlignment="Center"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="AceDetailText"
                                   Text="SGuard64  ·  SGuardSvc64"
                                   FontSize="11" Margin="17,4,0,0"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>

                    <!-- Status chip (replaces old circle) -->
                    <Border x:Name="AceBadge" Grid.Column="1"
                            CornerRadius="8" Padding="12,8"
                            VerticalAlignment="Center" HorizontalAlignment="Right"
                            MinWidth="88">
                        <Border.Background>
                            <SolidColorBrush x:Name="AceBadgeBg" Color="#111827"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
                            <ui:SymbolIcon x:Name="AceBadgeIcon" Symbol="CircleLine24" FontSize="20"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"
                                           Foreground="{StaticResource Gray}"/>
                            <TextBlock x:Name="AceBadgeLine1" Text="{DynamicResource String_BadgeIdle}"
                                       FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{StaticResource Gray}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Supported Games ── -->
            <TextBlock Text="{DynamicResource String_SupportedGames}" FontSize="10" FontWeight="SemiBold" Opacity="0.5"
                       Margin="2,6,0,8" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Game Row: Delta Force -->
            <Border Style="{StaticResource Card}" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="8"
                            Background="#1a2a40" VerticalAlignment="Center" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="XboxController24" FontSize="20" Foreground="#60a5fa"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource String_Game_DeltaForce}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="DeltaForceClient-Win64-Shipping" FontSize="10"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,1,0,0"/>
                    </StackPanel>
                    <Ellipse x:Name="DeltaDot" Grid.Column="2"
                             Width="9" Height="9"
                             VerticalAlignment="Center" HorizontalAlignment="Right"
                             Fill="{StaticResource Gray}"/>
                </Grid>
            </Border>

            <!-- Game Row: VALORANT -->
            <Border Style="{StaticResource Card}" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="8"
                            Background="#2a1a1f" VerticalAlignment="Center" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Target24" FontSize="20" Foreground="#f87171"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource String_Game_Valorant}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="VALORANT-Win64-Shipping" FontSize="10"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,1,0,0"/>
                    </StackPanel>
                    <Ellipse x:Name="ValorantDot" Grid.Column="2"
                             Width="9" Height="9"
                             VerticalAlignment="Center" HorizontalAlignment="Right"
                             Fill="{StaticResource Gray}"/>
                </Grid>
            </Border>

            <!-- ── Settings ── -->
            <TextBlock Text="{DynamicResource String_Settings}" FontSize="10" FontWeight="SemiBold" Opacity="0.5"
                       Margin="2,4,0,8" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>

            <Border Style="{StaticResource Card}" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource String_RunOnStartup}" FontSize="13" FontWeight="Medium"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource String_StartupDesc}" FontSize="10"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="AutoStartToggle" Grid.Column="1"
                                     Checked="AutoStartToggle_Checked"
                                     Unchecked="AutoStartToggle_Unchecked"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource String_AdminPrivileges}" FontSize="13" FontWeight="Medium"
                                   Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="AdminStatusDetailText" Text="{DynamicResource String_AdminStatusNormalDetail}" FontSize="10"
                                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="14" Padding="10,5" VerticalAlignment="Center"
                            Background="{ui:ThemeResource ControlFillColorSecondaryBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="AdminStatusDot" Style="{StaticResource Dot}" Fill="{StaticResource Gray}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="AdminStatusText" Text="{DynamicResource String_AdminStatusNormal}" FontSize="11"
                                       FontWeight="SemiBold" VerticalAlignment="Center"
                                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Footer ── -->
            <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0"
                       Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" FontSize="11">
                <Run Text="{DynamicResource String_MadeBy}"/>
                <Hyperlink NavigateUri="https://github.com/Ninthless" RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="@Ninthless" />
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
